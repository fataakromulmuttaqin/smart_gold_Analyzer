// ══════════════════════════════════════════════════════════════════════════════
// ▶ CONFLUENCE SCORING & SIGNAL ENGINE
// ══════════════════════════════════════════════════════════════════════════════
// Each confluence factor adds 1 point. Max score = 7
// Signals only fire during killzones with minimum confluence

// Long confluence
score_long = 0
score_long += ms_state == "bullish" ? 1 : 0
score_long += bull_grab ? 1 : 0
score_long += in_discount ? 1 : 0
score_long += bull_trend ? 1 : 0
score_long += htf_bias == 1 ? 1 : 0
score_long += bull_div ? 1 : 0
score_long += money_flow > 55 ? 1 : 0

// Short confluence
score_short = 0
score_short += ms_state == "bearish" ? 1 : 0
score_short += bear_grab ? 1 : 0
score_short += in_premium ? 1 : 0
score_short += bear_trend ? 1 : 0
score_short += htf_bias == -1 ? 1 : 0
score_short += bear_div ? 1 : 0
score_short += money_flow < 45 ? 1 : 0

// Signal thresholds
long_signal  = score_long >= 4 and rsi_val < 65
short_signal = score_short >= 4 and rsi_val > 35
strong_long  = score_long >= 5 and rsi_val < 60
strong_short = score_short >= 5 and rsi_val > 40

plotshape(strong_long,  "Strong Long",  shape.triangleup,   location.belowbar, color=C_BULL, size=size.normal, text="LONG",  textcolor=C_BULL)
plotshape(strong_short, "Strong Short", shape.triangledown,  location.abovebar, color=C_BEAR, size=size.normal, text="SHORT", textcolor=C_BEAR)
plotshape(long_signal and not strong_long,   "Long",  shape.triangleup,   location.belowbar, color=color.new(C_BULL,40), size=size.small)
plotshape(short_signal and not strong_short, "Short", shape.triangledown, location.abovebar, color=color.new(C_BEAR,40), size=size.small)



// ══════════════════════════════════════════════════════════════════════════════
// ▶ AUTO TP/SL LEVELS
// ══════════════════════════════════════════════════════════════════════════════
var line tp_line = na
var line sl_line = na
var label tp_lbl = na
var label sl_lbl = na

if tp_show and (strong_long or strong_short)
    if not na(tp_line)
        line.delete(tp_line)
    if not na(sl_line)
        line.delete(sl_line)
    if not na(tp_lbl)
        label.delete(tp_lbl)
    if not na(sl_lbl)
        label.delete(sl_lbl)
    
    float sl_dist = atr_val * tp_atr_mult
    float tp_dist = sl_dist * tp_rr
    
    if strong_long
        float sl_price = close - sl_dist
        float tp_price = close + tp_dist
        sl_line := line.new(bar_index, sl_price, bar_index + 20, sl_price, color=C_BEAR, width=2, style=line.style_dashed)
        tp_line := line.new(bar_index, tp_price, bar_index + 20, tp_price, color=C_BULL, width=2, style=line.style_dashed)
        sl_lbl  := label.new(bar_index + 20, sl_price, "SL " + str.tostring(math.round(sl_price, 2)), color=color.new(C_BEAR, 30), textcolor=C_WHITE, style=label.style_label_left, size=size.tiny)
        tp_lbl  := label.new(bar_index + 20, tp_price, "TP " + str.tostring(math.round(tp_price, 2)), color=color.new(C_BULL, 30), textcolor=C_WHITE, style=label.style_label_left, size=size.tiny)
    
    if strong_short
        float sl_price = close + sl_dist
        float tp_price = close - tp_dist
        sl_line := line.new(bar_index, sl_price, bar_index + 20, sl_price, color=C_BEAR, width=2, style=line.style_dashed)
        tp_line := line.new(bar_index, tp_price, bar_index + 20, tp_price, color=C_BULL, width=2, style=line.style_dashed)
        sl_lbl  := label.new(bar_index + 20, sl_price, "SL " + str.tostring(math.round(sl_price, 2)), color=color.new(C_BEAR, 30), textcolor=C_WHITE, style=label.style_label_left, size=size.tiny)
        tp_lbl  := label.new(bar_index + 20, tp_price, "TP " + str.tostring(math.round(tp_price, 2)), color=color.new(C_BULL, 30), textcolor=C_WHITE, style=label.style_label_left, size=size.tiny)

