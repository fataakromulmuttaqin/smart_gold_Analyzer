dash_t_pos = dash_pos == "Top Left" ? position.top_left : dash_pos == "Bottom Right" ? position.bottom_right : dash_pos == "Bottom Left" ? position.bottom_left : position.top_right

var table dash = table.new(dash_t_pos, 2, 14, bgcolor=color.new(#131722, 10), border_color=color.new(C_GOLD, 60), border_width=1, frame_color=color.new(C_GOLD, 40), frame_width=2)

if dash_show and barstate.islast
    bias_txt  = ms_state == "bullish" ? "BULLISH" : ms_state == "bearish" ? "BEARISH" : "NEUTRAL"
    bias_col  = ms_state == "bullish" ? C_BULL : ms_state == "bearish" ? C_BEAR : C_NEUTRAL
    trend_txt = bull_trend ? "UP" : bear_trend ? "DOWN" : "RANGE"
    trend_col = bull_trend ? C_BULL : bear_trend ? C_BEAR : C_NEUTRAL
    htf_txt   = htf_bias == 1 ? "BULL" : htf_bias == -1 ? "BEAR" : "NEUTRAL"
    htf_col   = htf_bias == 1 ? C_BULL : htf_bias == -1 ? C_BEAR : C_NEUTRAL
    pd_txt    = in_premium ? "PREMIUM" : in_discount ? "DISCOUNT" : "EQ"
    pd_col    = in_premium ? C_PREMIUM : in_discount ? C_DISCOUNT : C_NEUTRAL
    mf_txt    = money_flow > 60 ? "BUY PRESSURE" : money_flow < 40 ? "SELL PRESSURE" : "BALANCED"
    mf_col    = money_flow > 60 ? C_BULL : money_flow < 40 ? C_BEAR : C_NEUTRAL
    rsi_txt   = str.tostring(math.round(rsi_val, 1))
    rsi_col   = rsi_val > 70 ? C_BEAR : rsi_val < 30 ? C_BULL : C_NEUTRAL
    kz_txt    = is_london ? "LONDON" : is_ny ? "NEW YORK" : is_asia ? "ASIA" : "OFF"
    kz_col    = is_london ? C_KZ_LON : is_ny ? C_KZ_NY : is_asia ? C_KZ_ASIA : C_NEUTRAL
    
    sig_score = math.max(score_long, score_short)
    sig_txt   = strong_long ? "STRONG LONG" : strong_short ? "STRONG SHORT" : long_signal ? "LONG" : short_signal ? "SHORT" : "WAIT"
    sig_col   = strong_long or long_signal ? C_BULL : strong_short or short_signal ? C_BEAR : C_NEUTRAL
    
    div_txt   = bull_div ? "BULL DIV" : bear_div ? "BEAR DIV" : "-"
    div_col   = bull_div ? C_BULL : bear_div ? C_BEAR : C_NEUTRAL

    // Header
    table.cell(dash, 0, 0, "SmartGold Pro V2", text_color=C_GOLD, bgcolor=color.new(#131722, 0), text_size=size.normal)
    table.cell(dash, 1, 0, "", bgcolor=color.new(#131722, 0))
    table.merge_cells(dash, 0, 0, 1, 0)

    table.cell(dash, 0, 1, "Structure", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 1, bias_txt, text_color=bias_col, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    table.cell(dash, 0, 2, "HTF Bias", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
    table.cell(dash, 1, 2, htf_txt + " (" + mtf_tf + ")", text_color=htf_col, bgcolor=color.new(#131722, 30), text_size=size.small)

    table.cell(dash, 0, 3, "Trend", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 3, trend_txt, text_color=trend_col, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    table.cell(dash, 0, 4, "Zone", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
