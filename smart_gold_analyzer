    table.cell(dash, 0, 5, "Money Flow", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 5, mf_txt, text_color=mf_col, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    table.cell(dash, 0, 6, "RSI", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
    table.cell(dash, 1, 6, rsi_txt, text_color=rsi_col, bgcolor=color.new(#131722, 30), text_size=size.small)

    table.cell(dash, 0, 7, "Divergence", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 7, div_txt, text_color=div_col, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    table.cell(dash, 0, 8, "Killzone", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
    table.cell(dash, 1, 8, kz_txt, text_color=kz_col, bgcolor=color.new(#131722, 30), text_size=size.small)

    table.cell(dash, 0, 9, "ATR (14)", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 9, "$" + str.tostring(math.round(atr_val, 2)), text_color=C_GOLD, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    table.cell(dash, 0, 10, "FVG Active", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
    table.cell(dash, 1, 10, str.tostring(array.size(bull_fvg_boxes)) + "B / " + str.tostring(array.size(bear_fvg_boxes)) + "S", text_color=C_GOLD, bgcolor=color.new(#131722, 30), text_size=size.small)

    table.cell(dash, 0, 11, "Confluence", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 11, str.tostring(sig_score) + " / 7", text_color=sig_score >= 5 ? C_GOLD : sig_score >= 4 ? C_BULL : C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    // Signal row
    table.cell(dash, 0, 12, "Signal", text_color=C_WHITE, bgcolor=color.new(#0D47A1, 20), text_size=size.small)
    table.cell(dash, 1, 12, sig_txt, text_color=sig_col, bgcolor=color.new(#0D47A1, 20), text_size=size.normal)

    table.cell(dash, 0, 13, "Price", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 0), text_size=size.small)
    table.cell(dash, 1, 13, str.tostring(close, "#.##"), text_color=C_GOLD, bgcolor=color.new(#131722, 0), text_size=size.small)

