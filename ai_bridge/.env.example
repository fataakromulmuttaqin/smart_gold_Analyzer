# ═══════════════════════════════════════════════════════════════════════════
# SmartGold AI Bridge — Environment Configuration Example
# Copy to .env and fill in values. Never commit the real .env.
# ═══════════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# Shared secret that TradingView webhook MUST include in payload.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change-me-to-a-random-string

# ── MiniMax LLM ────────────────────────────────────────────────────────────
# Get your API key from https://www.minimax.io/ (MiniMax Open Platform)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# Model options: MiniMax-M2, MiniMax-M1, abab6.5-chat, etc.
MINIMAX_MODEL=MiniMax-M2
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_TIMEOUT=30
MINIMAX_MAX_TOKENS=1024
MINIMAX_TEMPERATURE=0.2

# Set true to bypass real LLM calls (returns canned decision — for dev/smoke test)
LLM_MOCK_MODE=false

# ── Macro Context (optional, graceful fallback if unset) ────────────────────
# DXY & US 10Y yield are fetched with multi-provider fallback:
#   1. yfinance (no key needed, but often blocked on VPS/servers)
#   2. Twelve Data — free tier 800 calls/day. Sign up: https://twelvedata.com
#   3. Alpha Vantage — free tier 25 calls/day. Sign up: https://www.alphavantage.co
#   4. Metals-API — free tier available. Sign up: https://metals-api.com
# If yfinance works on your machine, you can leave the fallback keys empty.
TWELVEDATA_API_KEY=
ALPHAVANTAGE_API_KEY=
METALS_API_KEY=

# Gold price validation bounds (reject stale/expired data outside this range)
# Per 2026: gold is ~$4,500-$5,000. Adjust if gold moves significantly.
GOLD_PRICE_MIN=3000
GOLD_PRICE_MAX=7000

# NewsAPI.org key for news sentiment context (optional)
NEWSAPI_KEY=
ENABLE_MACRO_CONTEXT=true

# ── Telegram Notifier (optional) ───────────────────────────────────────────
# Create bot via @BotFather, then get your chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Monitor (Telegram-based bot health notifications) ──────────────────────
# Alert if no signal received in this many hours (0 = disable silence alerts)
MONITOR_SILENCE_HOURS=6.0
# Send Telegram when a signal is skipped (by LLM or guards)
MONITOR_NOTIFY_SKIP=true
# Send Telegram when a signal is executed (order placed / decision=execute)
MONITOR_NOTIFY_EXECUTE=true

# ── Storage ────────────────────────────────────────────────────────────────
SQLITE_PATH=./data/signals.db

# ── Risk / Policy ──────────────────────────────────────────────────────────
# Minimum LLM confidence to mark a signal as "execute"
MIN_CONFIDENCE=0.60
# Cooldown (seconds) between processed signals for same symbol to avoid spam
SIGNAL_COOLDOWN_SECONDS=60

# ── Safety Guards ──────────────────────────────────────────────────────────
# Guards run after LLM decision, before broker execution. They can BLOCK
# (veto signal) or REDUCE (downgrade lot size).
GUARD_MAX_DAILY_TRADES=5
GUARD_MAX_DAILY_DRAWDOWN_R=-3.0
# Spread guard: block when spread > this value (points).
# Rescaled for gold at $4,500-$5,000: normal spread 30-80 pts, abnormal >150.
GUARD_MAX_SPREAD_POINTS=150.0
GUARD_NEWS_BLACKOUT=true
# ATR guard: block entries when H1 ATR exceeds threshold (extreme volatility).
# Rescaled for gold at $4,500-$5,000: normal ATR H1 = $15-35.
# Absolute mode: block if ATR > $50
GUARD_MAX_ATR=50.0
# Percentage mode (recommended, auto-scales with price changes):
# Block if ATR > 0.8% of entry price (e.g. $37.6 at $4,700 gold)
MAX_ATR_USE_PCT=true
MAX_ATR_PCT_BLOCK=0.8

# ── Stop Loss Policy ──────────────────────────────────────────────────────
# Policy options:
#   hybrid (RECOMMENDED) — PSAR distance clipped to [min, max] × ATR.
#                          Respects market structure but caps risk.
#   psar                 — Pure PSAR distance. Wide variance.
#   atr                  — Fixed ATR multiple (classic). Simple fallback.
SL_POLICY=hybrid
# Used by "atr" policy, and as fallback for "psar"/"hybrid" when PSAR missing
SL_ATR_MULT=1.5
# Hybrid-only: SL is bounded to [min, max] × ATR around the PSAR reference.
# Defaults tuned on XAUUSD H1 2023-2025 (min 0.8 prevents breakout shakeouts,
# max 2.5 caps worst-case loss while preserving most PSAR structure benefit).
SL_MIN_ATR_MULT=0.8
SL_MAX_ATR_MULT=2.5

# ── Breakeven Shift ──────────────────────────────────────────────────────
# When a trade moves this many R in favour, shift SL to entry + buffer×ATR
# (slight profit offset). Converts potential losers into scratch trades and
# typically adds +10-20% to Sharpe ratio on XAUUSD H1.
SL_BREAKEVEN_ENABLED=true
SL_BREAKEVEN_TRIGGER_R=1.0
SL_BREAKEVEN_BUFFER_ATR_MULT=0.1

# ── Trade plan defaults ──────────────────────────────────────────────────
# Reward:risk ratio used to compute the planned TP when the LLM does not
# return a suggested_rr value. 2.0 = "take profit at 2R".
SL_DEFAULT_RR=2.0
# Hypothetical equity for the dashboard's display-only lot/risk estimate.
# When MT5 is live the real account equity is used instead; this value
# only matters in signal-only mode (MT5_ENABLED=false).
PLAN_EQUITY_HINT=10000.0

# ── Risk Sizing ──────────────────────────────────────────────────────────
# Percent of equity to risk per trade. Actual lot is derived from:
#   lot = (equity × RISK_PCT) / (stop_distance × money_per_point_per_lot)
# so SL distance + this knob fully determine position size.
RISK_PER_TRADE_PCT=1.0
# Used when LLM decision.action=="reduce" (halve by default).
RISK_PER_TRADE_PCT_REDUCE=0.5

# ══════════════════════════════════════════════════════════════════════════
# ── cTrader MCP Execution (RECOMMENDED for Linux) ──────────────────────
# Pure HTTP POST to mcp.ctrader.com. No WebSocket, no Wine, no GUI,
# no OAuth2 app approval wait. Works on any Linux VPS headless.
# Supports IC Markets, Pepperstone, FxPro, and any cTrader broker.
#
# Setup steps (takes 2 minutes):
#   1. Open a cTrader account with IC Markets (or your broker)
#   2. In cTrader platform → Settings → generate an MCP/API token
#   3. Paste the full bearer token below (starts with "eyJ...")
#   4. Done! No app registration, no OAuth2 flow, no 3-day approval.
#
# Token format (base64-encoded JSON):
#   {"plant":"ctrader","environment":"demo","token":"<session_key>"}
#   - environment="demo" for paper trading, "live" for real money
#   - Generate a new token from cTrader when switching demo↔live
#
# Symbol naming: IC Markets cTrader uses "XAUUSD" (no prefix, no suffix).
# ══════════════════════════════════════════════════════════════════════════
CTRADER_ENABLED=false
# Full bearer token from cTrader (the long base64 string starting with eyJ...)
CTRADER_TOKEN=
# Symbol name exactly as the broker exposes it
CTRADER_SYMBOL=XAUUSD
# Set >0 to bypass risk-based sizing and always use this lot size
CTRADER_FIXED_LOT=0.0
# Label attached to orders (for filtering in breakeven reconciler)
CTRADER_LABEL=SmartGold

# ── MT5 Broker Execution (LEGACY — Windows/Wine only) ──────────────────
# Leave MT5_ENABLED=false to run the bridge as a pure LLM decision layer
# with no broker wiring. Turn on only on a Windows VPS (or Linux+Wine) that
# has the MetaTrader5 Python package installed (pip install MetaTrader5).
# On Linux the import fails silently and the bridge falls back to NoopExecutor
# — safe default, never touches real money.
MT5_ENABLED=false
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Symbol as your broker exposes it (Exness gold is typically "XAUUSDm"
# on trial/micro accounts; IC Markets is "XAUUSD"; FTMO is "XAUUSD.x").
# When set, this value overrides whatever TradingView sends in the
# webhook payload — so the dashboard, audit log and MT5 order ALL use
# your broker's ticker regardless of the chart's data feed.
MT5_SYMBOL=XAUUSD
# DEPRECATED: use RISK_PER_TRADE_PCT instead. Kept for backward compat.
MT5_RISK_PCT=1.0
# Set >0 to bypass risk-based sizing and always use this lot size
MT5_FIXED_LOT=0.0
# Max slippage (broker points) for order_send
MT5_DEVIATION=20
MT5_MAGIC=260512
# Absolute-last-resort fallback when ATR & PSAR both missing (gold 1pt ≈ $0.01)
MT5_FALLBACK_STOP_POINTS=2000
