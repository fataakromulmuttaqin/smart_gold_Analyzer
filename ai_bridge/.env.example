# ═══════════════════════════════════════════════════════════════════════════
# SmartGold AI Bridge — Environment Configuration Example
# Copy to .env and fill in values. Never commit the real .env.
# ═══════════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# Shared secret that TradingView webhook MUST include in payload.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change-me-to-a-random-string

# ── MiniMax LLM ────────────────────────────────────────────────────────────
# Get your API key from https://www.minimax.io/ (MiniMax Open Platform)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# Model options: MiniMax-M2, MiniMax-M1, abab6.5-chat, etc.
MINIMAX_MODEL=MiniMax-M2
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_TIMEOUT=30
MINIMAX_MAX_TOKENS=1024
MINIMAX_TEMPERATURE=0.2

# Set true to bypass real LLM calls (returns canned decision — for dev/smoke test)
LLM_MOCK_MODE=false

# ── Macro Context (optional, graceful fallback if unset) ────────────────────
# DXY & US 10Y yield are fetched with multi-provider fallback:
#   1. yfinance (no key needed, but often blocked on VPS/servers)
#   2. Twelve Data — free tier 800 calls/day. Sign up: https://twelvedata.com
#   3. Alpha Vantage — free tier 25 calls/day. Sign up: https://www.alphavantage.co
# If yfinance works on your machine, you can leave the fallback keys empty.
TWELVEDATA_API_KEY=
ALPHAVANTAGE_API_KEY=

# NewsAPI.org key for news sentiment context (optional)
NEWSAPI_KEY=
ENABLE_MACRO_CONTEXT=true

# ── Telegram Notifier (optional) ───────────────────────────────────────────
# Create bot via @BotFather, then get your chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Storage ────────────────────────────────────────────────────────────────
SQLITE_PATH=./data/signals.db

# ── Risk / Policy ──────────────────────────────────────────────────────────
# Minimum LLM confidence to mark a signal as "execute"
MIN_CONFIDENCE=0.60
# Cooldown (seconds) between processed signals for same symbol to avoid spam
SIGNAL_COOLDOWN_SECONDS=60

# ── Safety Guards ──────────────────────────────────────────────────────────
# Guards run after LLM decision, before broker execution. They can BLOCK
# (veto signal) or REDUCE (downgrade lot size).
GUARD_MAX_DAILY_TRADES=5
GUARD_MAX_DAILY_DRAWDOWN_R=-3.0
GUARD_MAX_SPREAD_POINTS=50.0
GUARD_NEWS_BLACKOUT=true

# ── MT5 Broker Execution (OPTIONAL) ────────────────────────────────────────
# Leave MT5_ENABLED=false to run the bridge as a pure LLM decision layer
# with no broker wiring. Turn on only on a Windows VPS (or Linux+Wine) that
# has the MetaTrader5 Python package installed (pip install MetaTrader5).
# On Linux the import fails silently and the bridge falls back to NoopExecutor
# — safe default, never touches real money.
MT5_ENABLED=false
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Symbol as your broker exposes it (Exness / IC Markets / etc. may vary)
MT5_SYMBOL=XAUUSD
# Risk as % of equity per trade; halved automatically when decision=reduce
MT5_RISK_PCT=1.0
# Set >0 to bypass risk-based sizing and always use this lot size
MT5_FIXED_LOT=0.0
# Max slippage (broker points) for order_send
MT5_DEVIATION=20
MT5_MAGIC=260512
# Used when alert.atr is missing (gold 1 point ≈ $0.01)
MT5_FALLBACK_STOP_POINTS=2000
