# Caddy reverse-proxy config for HTTPS termination in front of the AI bridge.
# Install: put this at /etc/caddy/Caddyfile, run `sudo systemctl reload caddy`.
# Caddy auto-provisions a Let's Encrypt certificate for the domain below.

# Replace sga.example.com with your real domain pointing (A record) at this VPS.
sga.example.com {
    encode zstd gzip

    # Forward webhook, health, root, dashboard UI, and dashboard API.
    # Anything else returns 404 to reduce attack surface.
    @allowed path /webhook/tradingview /health / /ui /ui/* /api/*
    handle @allowed {
        reverse_proxy 127.0.0.1:8080 {
            header_up X-Real-IP {remote_host}
        }
    }

    # OPTIONAL: protect the dashboard with HTTP Basic Auth.
    # Generate the hashed password on the VPS:
    #   caddy hash-password
    # then replace `REPLACE_ME_WITH_HASH` below and move the @allowed
    # matcher for /ui and /api above this block so those routes hit auth.
    # @dashboard path /ui /ui/* /api/*
    # basic_auth @dashboard {
    #     admin REPLACE_ME_WITH_HASH
    # }

    # Explicitly 404 other paths (e.g. /docs) if you don't want them public.
    handle {
        respond "Not found" 404
    }

    # Sensible security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        -Server
    }

    log {
        output file /var/log/caddy/sga-access.log
        format json
    }
}
