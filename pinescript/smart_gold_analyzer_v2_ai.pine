// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0
// © SmartGold Analyzer Pro | Inspired by LuxAlgo Price Action Concepts & Oscillator Matrix
// Designed specifically for XAU/USD (Gold) Analysis
// Compatible with TradingView Pine Script v6

//@version=6
indicator("SmartGold Analyzer Pro [XAU/USD]", shorttitle="SGA Pro", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ GROUP SETTINGS
// ══════════════════════════════════════════════════════════════════════════════
grpMS   = "📊 Market Structure"
grpOB   = "🟦 Order Blocks"
grpFVG  = "⚡ Fair Value Gaps (FVG)"
grpLiq  = "💧 Liquidity"
grpTrend = "📈 Trend & Momentum"
grpDash = "📋 Dashboard"
grpStyle = "🎨 Styling"

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — MARKET STRUCTURE
// ══════════════════════════════════════════════════════════════════════════════
ms_show      = input.bool(true,  "Show Market Structure",        group=grpMS)
ms_swing_len = input.int(10,     "Swing Lookback",  minval=5, maxval=50, group=grpMS)
ms_show_bos  = input.bool(true,  "Show BOS (Break of Structure)", group=grpMS)
ms_show_choch= input.bool(true,  "Show CHoCH (Change of Character)", group=grpMS)
ms_show_swing= input.bool(true,  "Show Swing High/Low Labels",   group=grpMS)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — ORDER BLOCKS
// ══════════════════════════════════════════════════════════════════════════════
ob_show      = input.bool(true,  "Show Order Blocks",            group=grpOB)
ob_len       = input.int(10,     "OB Lookback",  minval=5, maxval=50, group=grpOB)
ob_max       = input.int(5,      "Max OBs to Show", minval=1, maxval=10, group=grpOB)
ob_show_brk  = input.bool(true,  "Show Breaker Blocks",          group=grpOB)
ob_bull_col  = input.color(color.new(#2196F3, 75), "Bullish OB Color",  group=grpOB)
ob_bear_col  = input.color(color.new(#FF5252, 75), "Bearish OB Color",  group=grpOB)
ob_brk_col   = input.color(color.new(#9C27B0, 80), "Breaker Block Color", group=grpOB)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — FAIR VALUE GAPS
// ══════════════════════════════════════════════════════════════════════════════
fvg_show     = input.bool(true,  "Show Fair Value Gaps",         group=grpFVG)
fvg_bull_col = input.color(color.new(#00E676, 85), "Bullish FVG",  group=grpFVG)
fvg_bear_col = input.color(color.new(#FF1744, 85), "Bearish FVG",  group=grpFVG)
fvg_max      = input.int(5,      "Max FVGs to Show", minval=1, maxval=10, group=grpFVG)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — LIQUIDITY
// ══════════════════════════════════════════════════════════════════════════════
liq_show     = input.bool(true,  "Show Liquidity Zones",         group=grpLiq)
liq_len      = input.int(20,     "Liquidity Lookback", minval=10, maxval=100, group=grpLiq)
liq_eq_show  = input.bool(true,  "Show Equal Highs/Lows",        group=grpLiq)
liq_eq_thr   = input.float(0.1,  "EQH/EQL Threshold (%)", minval=0.01, maxval=1.0, step=0.01, group=grpLiq)
liq_grab_show= input.bool(true,  "Show Liquidity Grabs",         group=grpLiq)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — TREND & MOMENTUM
// ══════════════════════════════════════════════════════════════════════════════
trend_ema_fast = input.int(21,   "Fast EMA",  minval=5,  maxval=50,  group=grpTrend)
trend_ema_slow = input.int(50,   "Slow EMA",  minval=20, maxval=200, group=grpTrend)
trend_ema_base = input.int(200,  "Base EMA",  minval=50, maxval=500, group=grpTrend)
atr_len        = input.int(14,   "ATR Length", minval=5, maxval=50,  group=grpTrend)
rsi_len        = input.int(14,   "RSI Length", minval=5, maxval=50,  group=grpTrend)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — DASHBOARD
// ══════════════════════════════════════════════════════════════════════════════
dash_show    = input.bool(true,  "Show Dashboard",               group=grpDash)
dash_pos     = input.string("Top Right", "Position", options=["Top Right","Top Left","Bottom Right","Bottom Left"], group=grpDash)


// ══════════════════════════════════════════════════════════════════════════════
// ▶ COLORS & CONSTANTS
// ══════════════════════════════════════════════════════════════════════════════
C_BULL   = #26A69A
C_BEAR   = #EF5350
C_NEUTRAL= #787B86
C_GOLD   = #FFD700
C_WHITE  = #FFFFFF
C_BG     = color.new(#131722, 90)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ CORE CALCULATIONS — ATR, EMA, RSI
// ══════════════════════════════════════════════════════════════════════════════
atr_val   = ta.atr(atr_len)
ema_fast  = ta.ema(close, trend_ema_fast)
ema_slow  = ta.ema(close, trend_ema_slow)
ema_base  = ta.ema(close, trend_ema_base)
rsi_val   = ta.rsi(close, rsi_len)

// Money Flow (Smart Money Flow concept — volume-weighted directional pressure)
typ_price   = hlc3
mf_raw      = (close - open) / math.max(high - low, 0.001) * volume
mf_sum      = math.sum(mf_raw, 20)
mf_vol_sum  = math.sum(volume, 20)
money_flow  = mf_vol_sum > 0 ? (mf_sum / mf_vol_sum * 50 + 50) : 50.0

// Trend bias
bull_trend  = ema_fast > ema_slow and ema_slow > ema_base
bear_trend  = ema_fast < ema_slow and ema_slow < ema_base
trend_bias  = bull_trend ? 1 : bear_trend ? -1 : 0

// ══════════════════════════════════════════════════════════════════════════════
// ▶ SWING HIGH / LOW DETECTION
// ══════════════════════════════════════════════════════════════════════════════
swing_hi = ta.pivothigh(high, ms_swing_len, ms_swing_len)
swing_lo = ta.pivotlow(low,  ms_swing_len, ms_swing_len)

// Track last confirmed swing points
var float last_sh = na
var float last_sl = na
var int   last_sh_bar = 0
var int   last_sl_bar = 0

var float prev_sh = na
var float prev_sl = na

if not na(swing_hi)
    prev_sh    := last_sh
    last_sh    := swing_hi
    last_sh_bar:= bar_index - ms_swing_len

if not na(swing_lo)
    prev_sl    := last_sl
    last_sl    := swing_lo
    last_sl_bar:= bar_index - ms_swing_len


// ══════════════════════════════════════════════════════════════════════════════
// ▶ MARKET STRUCTURE — BOS & CHoCH DETECTION
// ══════════════════════════════════════════════════════════════════════════════
var string ms_state  = "neutral"  // "bullish" | "bearish" | "neutral"
var float  ms_level  = na

var line   ms_line   = na
var label  ms_label  = na

// Anti-overlap: track last BOS/CHoCH bar and level to prevent stacking
var int   last_ms_bar   = 0      // bar_index of last BOS/CHoCH label
var float last_ms_level = na     // price level of last BOS/CHoCH label
int       ms_cooldown   = ms_swing_len * 2  // minimum bars between labels
float     ms_level_thr  = ta.atr(14) * 0.3  // minimum price distance between labels

// BOS: Break of Structure (trend continuation)
// CHoCH: Change of Character (trend reversal)
bull_bos  = ms_show and ms_show_bos  and not na(last_sh) and close > last_sh and ms_state == "bullish"
bull_choch= ms_show and ms_show_choch and not na(last_sh) and close > last_sh and ms_state == "bearish"
bear_bos  = ms_show and ms_show_bos  and not na(last_sl) and close < last_sl and ms_state == "bearish"
bear_choch= ms_show and ms_show_choch and not na(last_sl) and close < last_sl and ms_state == "bullish"

// Helper: check if enough distance from last label (bar distance AND price distance)
ms_bar_ok    = (bar_index - last_ms_bar) >= ms_cooldown
ms_lvl_ok_hi = na(last_ms_level) or math.abs(last_sh - last_ms_level) > ms_level_thr
ms_lvl_ok_lo = na(last_ms_level) or math.abs(last_sl - last_ms_level) > ms_level_thr

if bull_choch and (ms_bar_ok or ms_lvl_ok_hi)
    ms_state := "bullish"
    line.new(last_sh_bar, last_sh, bar_index, last_sh, color=C_BULL, width=1, style=line.style_dashed)
    label.new(bar_index, last_sh, "CHoCH", color=color.new(C_BULL, 20), textcolor=C_WHITE, style=label.style_label_down, size=size.small)
    last_ms_bar   := bar_index
    last_ms_level := last_sh
else if bull_choch
    ms_state := "bullish"

if bull_bos and (ms_bar_ok or ms_lvl_ok_hi)
    line.new(last_sh_bar, last_sh, bar_index, last_sh, color=C_BULL, width=1)
    label.new(bar_index, last_sh, "BOS", color=color.new(C_BULL, 20), textcolor=C_WHITE, style=label.style_label_down, size=size.small)
    last_ms_bar   := bar_index
    last_ms_level := last_sh

if bear_choch and (ms_bar_ok or ms_lvl_ok_lo)
    ms_state := "bearish"
    line.new(last_sl_bar, last_sl, bar_index, last_sl, color=C_BEAR, width=1, style=line.style_dashed)
    label.new(bar_index, last_sl, "CHoCH", color=color.new(C_BEAR, 20), textcolor=C_WHITE, style=label.style_label_up, size=size.small)
    last_ms_bar   := bar_index
    last_ms_level := last_sl
else if bear_choch
    ms_state := "bearish"

if bear_bos and (ms_bar_ok or ms_lvl_ok_lo)
    line.new(last_sl_bar, last_sl, bar_index, last_sl, color=C_BEAR, width=1)
    label.new(bar_index, last_sl, "BOS", color=color.new(C_BEAR, 20), textcolor=C_WHITE, style=label.style_label_up, size=size.small)
    last_ms_bar   := bar_index
    last_ms_level := last_sl

// Initialize state from first valid structure
if ms_state == "neutral" and not na(last_sh) and not na(last_sl)
    ms_state := last_sh > last_sl ? "bullish" : "bearish"

// Swing High/Low labels — also with anti-overlap logic
var int last_hh_bar = 0
var int last_ll_bar = 0

if ms_show and ms_show_swing
    if not na(swing_hi) and (bar_index - last_hh_bar) >= ms_swing_len
        label.new(bar_index - ms_swing_len, swing_hi, "HH", color=color.new(C_BEAR,60), textcolor=C_WHITE, style=label.style_label_down, size=size.tiny)
        last_hh_bar := bar_index
    if not na(swing_lo) and (bar_index - last_ll_bar) >= ms_swing_len
        label.new(bar_index - ms_swing_len, swing_lo, "LL", color=color.new(C_BULL,60), textcolor=C_WHITE, style=label.style_label_up, size=size.tiny)
        last_ll_bar := bar_index


// ══════════════════════════════════════════════════════════════════════════════
// ▶ ORDER BLOCKS
// ══════════════════════════════════════════════════════════════════════════════
// Bullish OB: last bearish candle before a bullish impulse (near swing low)
// Bearish OB: last bullish candle before a bearish impulse (near swing high)

var box[]  bull_ob_boxes  = array.new<box>()
var box[]  bear_ob_boxes  = array.new<box>()
var box[]  brk_ob_boxes   = array.new<box>()

// Detect OB on confirmed swing pivots
ob_bull_cond = ob_show and not na(swing_lo) and close[ms_swing_len] < open[ms_swing_len]  // bearish candle at swing low = potential bullish OB
ob_bear_cond = ob_show and not na(swing_hi) and close[ms_swing_len] > open[ms_swing_len]  // bullish candle at swing high = potential bearish OB

if ob_bull_cond
    ob_top    = math.max(open[ms_swing_len], close[ms_swing_len])
    ob_bot    = math.min(open[ms_swing_len], close[ms_swing_len])
    new_box   = box.new(bar_index - ms_swing_len * 2, ob_top, bar_index + 20, ob_bot, border_color=color.new(#2196F3,30), bgcolor=ob_bull_col, border_width=1)
    array.push(bull_ob_boxes, new_box)
    if array.size(bull_ob_boxes) > ob_max
        box.delete(array.shift(bull_ob_boxes))

if ob_bear_cond
    ob_top    = math.max(open[ms_swing_len], close[ms_swing_len])
    ob_bot    = math.min(open[ms_swing_len], close[ms_swing_len])
    new_box   = box.new(bar_index - ms_swing_len * 2, ob_top, bar_index + 20, ob_bot, border_color=color.new(#FF5252,30), bgcolor=ob_bear_col, border_width=1)
    array.push(bear_ob_boxes, new_box)
    if array.size(bear_ob_boxes) > ob_max
        box.delete(array.shift(bear_ob_boxes))

// Extend active OB boxes to current bar & check mitigation
if ob_show and array.size(bull_ob_boxes) > 0
    for i = 0 to array.size(bull_ob_boxes) - 1
        b = array.get(bull_ob_boxes, i)
        if not na(b)
            box.set_right(b, bar_index + 5)
            // Mitigate if price closes below OB bottom
            if close < box.get_bottom(b)
                if ob_show_brk
                    brk = box.copy(b)
                    box.set_bgcolor(brk, ob_brk_col)
                    array.push(brk_ob_boxes, brk)
                    if array.size(brk_ob_boxes) > ob_max
                        box.delete(array.shift(brk_ob_boxes))
                box.delete(b)
                array.remove(bull_ob_boxes, i)
                break

if ob_show and array.size(bear_ob_boxes) > 0
    for i = 0 to array.size(bear_ob_boxes) - 1
        b = array.get(bear_ob_boxes, i)
        if not na(b)
            box.set_right(b, bar_index + 5)
            // Mitigate if price closes above OB top
            if close > box.get_top(b)
                if ob_show_brk
                    brk = box.copy(b)
                    box.set_bgcolor(brk, ob_brk_col)
                    array.push(brk_ob_boxes, brk)
                    if array.size(brk_ob_boxes) > ob_max
                        box.delete(array.shift(brk_ob_boxes))
                box.delete(b)
                array.remove(bear_ob_boxes, i)
                break

// Extend breaker blocks
if ob_show_brk and array.size(brk_ob_boxes) > 0
    for i = 0 to array.size(brk_ob_boxes) - 1
        b = array.get(brk_ob_boxes, i)
        if not na(b)
            box.set_right(b, bar_index + 5)


// ══════════════════════════════════════════════════════════════════════════════
// ▶ FAIR VALUE GAPS (FVG)
// ══════════════════════════════════════════════════════════════════════════════
// Bullish FVG: low[0] > high[2]  → gap between high 2 bars ago and current low
// Bearish FVG: high[0] < low[2] → gap between low 2 bars ago and current high

var box[] bull_fvg_boxes = array.new<box>()
var box[] bear_fvg_boxes = array.new<box>()

bull_fvg_cond = fvg_show and low > high[2]
bear_fvg_cond = fvg_show and high < low[2]

if bull_fvg_cond
    fb = box.new(bar_index - 2, low, bar_index + 15, high[2], border_color=color.new(#00E676, 50), bgcolor=fvg_bull_col, border_width=1)
    array.push(bull_fvg_boxes, fb)
    if array.size(bull_fvg_boxes) > fvg_max
        box.delete(array.shift(bull_fvg_boxes))

if bear_fvg_cond
    fb = box.new(bar_index - 2, low[2], bar_index + 15, high, border_color=color.new(#FF1744, 50), bgcolor=fvg_bear_col, border_width=1)
    array.push(bear_fvg_boxes, fb)
    if array.size(bear_fvg_boxes) > fvg_max
        box.delete(array.shift(bear_fvg_boxes))

// Extend & mitigate FVGs
if fvg_show and array.size(bull_fvg_boxes) > 0
    for i = 0 to array.size(bull_fvg_boxes) - 1
        b = array.get(bull_fvg_boxes, i)
        if not na(b)
            box.set_right(b, bar_index + 5)
            if close < box.get_bottom(b)
                box.delete(b)
                array.remove(bull_fvg_boxes, i)
                break

if fvg_show and array.size(bear_fvg_boxes) > 0
    for i = 0 to array.size(bear_fvg_boxes) - 1
        b = array.get(bear_fvg_boxes, i)
        if not na(b)
            box.set_right(b, bar_index + 5)
            if close > box.get_top(b)
                box.delete(b)
                array.remove(bear_fvg_boxes, i)
                break


// ══════════════════════════════════════════════════════════════════════════════
// ▶ LIQUIDITY — EQUAL HIGHS & LOWS
// ══════════════════════════════════════════════════════════════════════════════
liq_ph = ta.pivothigh(high, liq_len, liq_len)
liq_pl = ta.pivotlow(low,  liq_len, liq_len)

var float eq_hi_level = na
var float eq_lo_level = na
var int   eq_hi_bar   = 0
var int   eq_lo_bar   = 0
var float prev_liq_ph = na
var float prev_liq_pl = na

if not na(liq_ph)
    if not na(prev_liq_ph)
        thr_hi = prev_liq_ph * liq_eq_thr / 100
        if math.abs(liq_ph - prev_liq_ph) < thr_hi and liq_eq_show
            eq_hi_level := (liq_ph + prev_liq_ph) / 2
            eq_hi_bar   := bar_index - liq_len
            line.new(bar_index - liq_len * 2, eq_hi_level, bar_index + 10, eq_hi_level, color=color.new(C_BEAR, 30), style=line.style_dotted, width=2)
            label.new(bar_index - liq_len, eq_hi_level, "EQH 💧", color=color.new(C_BEAR, 50), textcolor=C_WHITE, style=label.style_label_down, size=size.tiny)
    prev_liq_ph := liq_ph

if not na(liq_pl)
    if not na(prev_liq_pl)
        thr_lo = prev_liq_pl * liq_eq_thr / 100
        if math.abs(liq_pl - prev_liq_pl) < thr_lo and liq_eq_show
            eq_lo_level := (liq_pl + prev_liq_pl) / 2
            eq_lo_bar   := bar_index - liq_len
            line.new(bar_index - liq_len * 2, eq_lo_level, bar_index + 10, eq_lo_level, color=color.new(C_BULL, 30), style=line.style_dotted, width=2)
            label.new(bar_index - liq_len, eq_lo_level, "EQL 💧", color=color.new(C_BULL, 50), textcolor=C_WHITE, style=label.style_label_up, size=size.tiny)
    prev_liq_pl := liq_pl

// ══════════════════════════════════════════════════════════════════════════════
// ▶ LIQUIDITY GRABS
// ══════════════════════════════════════════════════════════════════════════════
// Bull liq grab: wick below recent low but closes above → demand sweep
// Bear liq grab: wick above recent high but closes below → supply sweep
recent_lo = ta.lowest(low, liq_len)
recent_hi = ta.highest(high, liq_len)

bull_grab = liq_grab_show and low < recent_lo[1] and close > low and (close - low) > (high - close) * 0.5
bear_grab = liq_grab_show and high > recent_hi[1] and close < high and (high - close) > (close - low) * 0.5

if bull_grab
    box.new(bar_index - 1, low, bar_index + 1, close, border_color=color.new(C_BULL, 0), bgcolor=color.new(C_BULL, 70), border_width=2)
    label.new(bar_index, low, "Bull Grab", color=color.new(C_BULL, 20), textcolor=C_WHITE, style=label.style_label_up, size=size.small)

if bear_grab
    box.new(bar_index - 1, close, bar_index + 1, high, border_color=color.new(C_BEAR, 0), bgcolor=color.new(C_BEAR, 70), border_width=2)
    label.new(bar_index, high, "Bear Grab", color=color.new(C_BEAR, 20), textcolor=C_WHITE, style=label.style_label_down, size=size.small)


// ══════════════════════════════════════════════════════════════════════════════
// ▶ EMA PLOTS
// ══════════════════════════════════════════════════════════════════════════════
plot(ema_fast, "EMA Fast",  color=color.new(C_GOLD, 20),    linewidth=1)
plot(ema_slow, "EMA Slow",  color=color.new(#FF9800, 30),   linewidth=1)
plot(ema_base, "EMA Base",  color=color.new(C_NEUTRAL, 40), linewidth=2)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ CANDLE COLORING — Based on Market Structure State
// ══════════════════════════════════════════════════════════════════════════════
candle_col = ms_state == "bullish" ? color.new(C_BULL, 60) : ms_state == "bearish" ? color.new(C_BEAR, 60) : color.new(C_NEUTRAL, 70)
barcolor(candle_col)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ SIGNAL DETECTION — TRADE SIGNALS
// ══════════════════════════════════════════════════════════════════════════════
// Long Signal: Bull structure + Price near OB/FVG + Bull liq grab + EMA aligned
long_signal  = ms_state == "bullish" and bull_grab and rsi_val < 60 and ema_fast > ema_slow and money_flow > 50

// Short Signal: Bear structure + Price near OB/FVG + Bear liq grab + EMA aligned
short_signal = ms_state == "bearish" and bear_grab and rsi_val > 40 and ema_fast < ema_slow and money_flow < 50

// Strong signals — full confluence
strong_long  = long_signal  and bull_trend and rsi_val < 55 and money_flow > 60
strong_short = short_signal and bear_trend and rsi_val > 45 and money_flow < 40

plotshape(strong_long,  "Strong Long",  shape.triangleup,   location.belowbar, color=C_BULL, size=size.normal, text="LONG 🥇",  textcolor=C_BULL)
plotshape(strong_short, "Strong Short", shape.triangledown,  location.abovebar, color=C_BEAR, size=size.normal, text="SHORT 🥇", textcolor=C_BEAR)
plotshape(long_signal  and not strong_long,  "Long",  shape.triangleup,   location.belowbar, color=color.new(C_BULL,40), size=size.small)
plotshape(short_signal and not strong_short, "Short", shape.triangledown,  location.abovebar, color=color.new(C_BEAR,40), size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ SMART MONEY FLOW — Oscillator (displayed as colored background)
// ══════════════════════════════════════════════════════════════════════════════
mf_bull_bg = money_flow > 60
mf_bear_bg = money_flow < 40
bgcolor(mf_bull_bg ? color.new(C_BULL, 97) : mf_bear_bg ? color.new(C_BEAR, 97) : na, title="Money Flow BG")


// ══════════════════════════════════════════════════════════════════════════════
// ▶ GOLD-SPECIFIC: ATR-Based Dynamic S/R Zones
// ══════════════════════════════════════════════════════════════════════════════
// Gold moves in large ATR ranges — plot key ATR levels from recent swing points
var line atr_bull_line = na
var line atr_bear_line = na

if not na(last_sl) and not na(atr_val)
    if not na(atr_bull_line)
        line.delete(atr_bull_line)
    atr_bull_line := line.new(last_sl_bar, last_sl + atr_val, bar_index + 10, last_sl + atr_val, color=color.new(C_BULL, 50), style=line.style_dashed, width=1)

if not na(last_sh) and not na(atr_val)
    if not na(atr_bear_line)
        line.delete(atr_bear_line)
    atr_bear_line := line.new(last_sh_bar, last_sh - atr_val, bar_index + 10, last_sh - atr_val, color=color.new(C_BEAR, 50), style=line.style_dashed, width=1)


// ══════════════════════════════════════════════════════════════════════════════
// ▶ DASHBOARD — Info Panel
// ══════════════════════════════════════════════════════════════════════════════

// Resolve table position OUTSIDE if block (Pine Script requires single-line ternary or var at top scope)
dash_t_pos = dash_pos == "Top Left" ? position.top_left : dash_pos == "Bottom Right" ? position.bottom_right : dash_pos == "Bottom Left" ? position.bottom_left : position.top_right

var table dash = table.new(dash_t_pos, 2, 10, bgcolor=color.new(#131722, 10), border_color=color.new(C_GOLD, 60), border_width=1, frame_color=color.new(C_GOLD, 40), frame_width=2)

if dash_show and barstate.islast
    // Text labels
    bias_txt  = ms_state == "bullish" ? "🟢 BULLISH" : ms_state == "bearish" ? "🔴 BEARISH" : "⚪ NEUTRAL"
    trend_txt = bull_trend ? "UP TREND" : bear_trend ? "DOWN TREND" : "RANGING"
    mf_txt    = money_flow > 60 ? "STRONG BUY" : money_flow < 40 ? "STRONG SELL" : "BALANCED"
    rsi_txt   = rsi_val > 70 ? "Overbought" : rsi_val < 30 ? "Oversold" : str.tostring(math.round(rsi_val, 1))
    atr_txt   = str.tostring(math.round(atr_val, 2))
    sig_txt   = strong_long ? "STRONG LONG" : strong_short ? "STRONG SHORT" : long_signal ? "LONG" : short_signal ? "SHORT" : "WAIT"
    sig_col   = strong_long or long_signal ? C_BULL : strong_short or short_signal ? C_BEAR : C_NEUTRAL
    bias_col  = ms_state == "bullish" ? C_BULL : ms_state == "bearish" ? C_BEAR : C_NEUTRAL
    trend_col = bull_trend ? C_BULL : bear_trend ? C_BEAR : C_NEUTRAL
    mf_col    = money_flow > 60 ? C_BULL : money_flow < 40 ? C_BEAR : C_NEUTRAL
    rsi_col   = rsi_val > 70 ? C_BEAR : rsi_val < 30 ? C_BULL : C_NEUTRAL
    grab_txt  = bull_grab ? "Bull Sweep" : bear_grab ? "Bear Sweep" : "-"
    grab_col  = bull_grab ? C_BULL : bear_grab ? C_BEAR : C_NEUTRAL
    fvg_txt   = str.tostring(array.size(bull_fvg_boxes)) + "B / " + str.tostring(array.size(bear_fvg_boxes)) + "S"

    // Header — v6: use table.merge_cells() instead of colspan parameter
    table.cell(dash, 0, 0, "SmartGold XAU/USD", text_color=C_GOLD, bgcolor=color.new(#131722, 0), text_size=size.normal)
    table.cell(dash, 1, 0, "", bgcolor=color.new(#131722, 0))
    table.merge_cells(dash, 0, 0, 1, 0)

    // Row 1
    table.cell(dash, 0, 1, "Structure Bias", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 1, bias_txt, text_color=bias_col, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    // Row 2
    table.cell(dash, 0, 2, "Trend (EMA)", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
    table.cell(dash, 1, 2, trend_txt, text_color=trend_col, bgcolor=color.new(#131722, 30), text_size=size.small)

    // Row 3
    table.cell(dash, 0, 3, "Money Flow", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 3, mf_txt, text_color=mf_col, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    // Row 4
    table.cell(dash, 0, 4, "RSI (" + str.tostring(rsi_len) + ")", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
    table.cell(dash, 1, 4, rsi_txt, text_color=rsi_col, bgcolor=color.new(#131722, 30), text_size=size.small)

    // Row 5
    table.cell(dash, 0, 5, "ATR (14)", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 5, "$ " + atr_txt, text_color=C_GOLD, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    // Row 6
    table.cell(dash, 0, 6, "Liq Grab", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
    table.cell(dash, 1, 6, grab_txt, text_color=grab_col, bgcolor=color.new(#131722, 30), text_size=size.small)

    // Row 7
    table.cell(dash, 0, 7, "FVG Active", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 7, fvg_txt, text_color=C_GOLD, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    // Row 8 — SIGNAL
    table.cell(dash, 0, 8, "Signal", text_color=C_WHITE, bgcolor=color.new(#0D47A1, 20), text_size=size.small)
    table.cell(dash, 1, 8, sig_txt, text_color=sig_col, bgcolor=color.new(#0D47A1, 20), text_size=size.normal)

    // Row 9 — Last price
    table.cell(dash, 0, 9, "Price", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 0), text_size=size.small)
    table.cell(dash, 1, 9, str.tostring(close, "#.##"), text_color=C_GOLD, bgcolor=color.new(#131722, 0), text_size=size.small)


// ══════════════════════════════════════════════════════════════════════════════
// ▶ ALERTS
// ══════════════════════════════════════════════════════════════════════════════
alertcondition(strong_long,  "🥇 Strong Long Signal",  "SmartGold: STRONG LONG signal on XAU/USD — Full confluence detected!")
alertcondition(strong_short, "🥇 Strong Short Signal", "SmartGold: STRONG SHORT signal on XAU/USD — Full confluence detected!")
alertcondition(long_signal,  "📈 Long Signal",         "SmartGold: Long signal on XAU/USD")
alertcondition(short_signal, "📉 Short Signal",        "SmartGold: Short signal on XAU/USD")
alertcondition(bull_choch,   "🔄 Bullish CHoCH",       "SmartGold: Bullish Change of Character detected on XAU/USD")
alertcondition(bear_choch,   "🔄 Bearish CHoCH",       "SmartGold: Bearish Change of Character detected on XAU/USD")
alertcondition(bull_bos,     "↑ Bullish BOS",          "SmartGold: Bullish Break of Structure on XAU/USD")
alertcondition(bear_bos,     "↓ Bearish BOS",          "SmartGold: Bearish Break of Structure on XAU/USD")
alertcondition(bull_grab,    "🎯 Bullish Liq Grab",    "SmartGold: Bullish Liquidity Grab on XAU/USD — Potential reversal up")
alertcondition(bear_grab,    "🎯 Bearish Liq Grab",    "SmartGold: Bearish Liquidity Grab on XAU/USD — Potential reversal down")
alertcondition(bull_fvg_cond,"⚡ Bullish FVG",         "SmartGold: Bullish Fair Value Gap detected on XAU/USD")
alertcondition(bear_fvg_cond,"⚡ Bearish FVG",         "SmartGold: Bearish Fair Value Gap detected on XAU/USD")



// ══════════════════════════════════════════════════════════════════════════════
// ▶ AI BRIDGE — WEBHOOK JSON ALERTS (v2 addition)
// ══════════════════════════════════════════════════════════════════════════════
// These alerts emit a JSON payload compatible with the SmartGold AI Bridge
// FastAPI server (ai_bridge/). The `secret` must match WEBHOOK_SECRET on
// the server.
//
// Pine Script v6 alertcondition() message is a const string (TradingView
// placeholders like {{close}} {{ticker}} {{interval}} are substituted by
// the TradingView server). For fully-dynamic runtime values (EMAs, RSI,
// ms_state …) we use alert() with freq=alert.freq_once_per_bar_close and
// a runtime-built JSON string — this is the officially supported pattern.
//
// TradingView alert setup:
//   1. Create an alert on this indicator.
//   2. Condition: select this indicator → "Any alert() function call".
//   3. Webhook URL: https://your-vps.example.com/webhook/tradingview
//   4. Leave Message field empty (alert() already provides the payload).
// ══════════════════════════════════════════════════════════════════════════════

grpAI = "🤖 AI Bridge (Webhook)"
ai_enable_webhook = input.bool(true,  "Enable AI bridge webhook alerts", group=grpAI)
ai_webhook_secret = input.string("CHANGE_ME", "Webhook Secret (must match server)", group=grpAI, tooltip="Shared secret with your AI bridge server. Generate with: python -c \"import secrets; print(secrets.token_urlsafe(32))\"")
ai_send_weak      = input.bool(false, "Also send non-strong signals", group=grpAI, tooltip="If off, only strong_long / strong_short trigger the webhook. Weak signals are very noisy.")
ai_send_structure = input.bool(false, "Also send BOS/CHoCH events",    group=grpAI)

// Helper: build compact JSON payload for a given signal name.
// Runtime values are formatted with fixed precision so the Python server
// can parse them cleanly with json.loads().
//
// Note on Pine v6 line continuation: we use a TRAILING '+' at the end of
// every continued line and keep ALL body lines at the same indent depth.
// Mixing indent depths inside a multi-line expression (e.g. the opening
// '{' at 4 spaces and the closing '}' at a different depth) trips the
// parser with: "Syntax error at input 'end of line without line
// continuation' (CE10156)".
f_ai_payload(string sig_name) =>
    '{"secret":"'    + ai_webhook_secret                              + '",' +
    '"symbol":"'     + syminfo.ticker                                 + '",' +
    '"timeframe":"'  + timeframe.period                               + '",' +
    '"signal":"'     + sig_name                                       + '",' +
    '"price":'       + str.tostring(close,      "#.####")             + ','  +
    '"time":"'       + str.format_time(time, "yyyy-MM-dd'T'HH:mm:ssZ", "UTC") + '",' +
    '"ms_state":"'   + ms_state                                       + '",' +
    '"rsi":'         + str.tostring(rsi_val,    "#.##")               + ','  +
    '"atr":'         + str.tostring(atr_val,    "#.####")             + ','  +
    '"money_flow":'  + str.tostring(money_flow, "#.##")               + ','  +
    '"ema_fast":'    + str.tostring(ema_fast,   "#.####")             + ','  +
    '"ema_slow":'    + str.tostring(ema_slow,   "#.####")             + ','  +
    '"ema_base":'    + str.tostring(ema_base,   "#.####")             + '}'

// Dispatch: each signal fires its own alert() with a tailored payload.
// alert.freq_once_per_bar_close = exactly one fire per confirmed bar.
if ai_enable_webhook and barstate.isconfirmed
    if strong_long
        alert(f_ai_payload("strong_long"), alert.freq_once_per_bar_close)
    else if strong_short
        alert(f_ai_payload("strong_short"), alert.freq_once_per_bar_close)
    else if ai_send_weak and long_signal
        alert(f_ai_payload("long"), alert.freq_once_per_bar_close)
    else if ai_send_weak and short_signal
        alert(f_ai_payload("short"), alert.freq_once_per_bar_close)

    if ai_send_structure
        if bull_choch
            alert(f_ai_payload("bull_choch"), alert.freq_once_per_bar_close)
        else if bear_choch
            alert(f_ai_payload("bear_choch"), alert.freq_once_per_bar_close)
