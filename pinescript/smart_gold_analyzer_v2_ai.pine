// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0
// © SmartGold Analyzer Pro — PSAR + EMA Ribbon + Volume Strategy
// Designed specifically for XAU/USD (Gold) on H1
// Compatible with TradingView Pine Script v6

//@version=6
indicator("SmartGold Analyzer Pro [XAU/USD] — PSAR+EMA+Vol", shorttitle="SGA PSAR", overlay=true, max_labels_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ STRATEGY OVERVIEW
// ──────────────────────────────────────────────────────────────────────────────
// Entry LONG  (H1, all must be true):
//   1. close > EMA200                         [trend filter]
//   2. EMA20 > EMA50 > EMA100                 [ribbon aligned]
//   3. close crossup EMA20 this bar           [pullback-reclaim trigger]
//   4. volume > SMA(vol,20) * 1.3             [volume confirmation]
//   5. PSAR below price                       [PSAR trend agreement]
//
// Entry SHORT: mirror (close<EMA200, EMA20<EMA50<EMA100, close crossdn EMA20,
//              vol>SMA*1.3, PSAR above price)
//
// Exit LONG (priority order, first match wins — earliest is safest):
//   1. PSAR flipped above price               → exit_long (reason: psar_flip)
//   2. close < EMA20                          → exit_long (reason: trend_break)
//   3. bars_since_entry ≥ 6                   → exit_long (reason: time_max)
//   4. bars_since_entry ≥ 4 AND volume declining 2 bars
//                                             → exit_long (reason: volume_fade)
// Exit SHORT: mirror.
//
// Risk:
//   SL = current PSAR value at entry (natural structural stop)
//   TP = none hardcoded — the AI bridge / LLM decides on R:R
// ══════════════════════════════════════════════════════════════════════════════


// ══════════════════════════════════════════════════════════════════════════════
// ▶ GROUP SETTINGS
// ══════════════════════════════════════════════════════════════════════════════
grpEMA   = "📈 EMA Ribbon"
grpPSAR  = "🎯 Parabolic SAR"
grpVOL   = "📊 Volume"
grpEXIT  = "🚪 Exit Rules"
grpDash  = "📋 Dashboard"
grpAI    = "🤖 AI Bridge (Webhook)"


// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — EMA
// ══════════════════════════════════════════════════════════════════════════════
ema_fast_len = input.int(20,  "EMA Fast",   minval=2, group=grpEMA)
ema_mid_len  = input.int(50,  "EMA Medium", minval=2, group=grpEMA)
ema_slow_len = input.int(100, "EMA Slow",   minval=2, group=grpEMA)
ema_base_len = input.int(200, "EMA Base (trend filter)", minval=2, group=grpEMA)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — PSAR (defaults per TradingView docs: start=0.02, inc=0.02, max=0.2)
// ══════════════════════════════════════════════════════════════════════════════
psar_start = input.float(0.02, "PSAR Start",     minval=0.001, step=0.001, group=grpPSAR)
psar_inc   = input.float(0.02, "PSAR Increment", minval=0.001, step=0.001, group=grpPSAR)
psar_max   = input.float(0.20, "PSAR Maximum",   minval=0.01,  step=0.01,  group=grpPSAR)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — VOLUME
// ══════════════════════════════════════════════════════════════════════════════
vol_sma_len       = input.int(20,   "Volume SMA Length",     minval=2,  group=grpVOL)
vol_entry_mult    = input.float(1.3, "Entry volume threshold (x SMA)",  minval=1.0, step=0.1, group=grpVOL)
vol_strong_mult   = input.float(1.8, "Strong-signal volume threshold (x SMA)", minval=1.0, step=0.1, group=grpVOL)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — EXIT
// ══════════════════════════════════════════════════════════════════════════════
exit_min_bars = input.int(4, "Minimum bars before time-based exit", minval=1, group=grpEXIT)
exit_max_bars = input.int(6, "Maximum bars before forced exit",     minval=2, group=grpEXIT)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — DASHBOARD
// ══════════════════════════════════════════════════════════════════════════════
dash_show = input.bool(true, "Show Dashboard", group=grpDash)
dash_pos  = input.string("Top Right", "Position", options=["Top Right","Top Left","Bottom Right","Bottom Left"], group=grpDash)

// ══════════════════════════════════════════════════════════════════════════════
// ▶ INPUTS — AI BRIDGE
// ══════════════════════════════════════════════════════════════════════════════
ai_enable_webhook = input.bool(true,  "Enable AI bridge webhook alerts", group=grpAI)
ai_webhook_secret = input.string("CHANGE_ME", "Webhook Secret (must match server)", group=grpAI, tooltip="Generate with: python -c \"import secrets; print(secrets.token_urlsafe(32))\"")
ai_send_weak      = input.bool(false, "Also send non-strong entries", group=grpAI, tooltip="If off, only strong_long / strong_short trigger entry webhooks")
ai_send_exits     = input.bool(true,  "Send exit signals to bridge",  group=grpAI, tooltip="Exits are always informational (never spam) — recommended ON")


// ══════════════════════════════════════════════════════════════════════════════
// ▶ COLORS
// ══════════════════════════════════════════════════════════════════════════════
C_BULL   = #26A69A
C_BEAR   = #EF5350
C_NEUTRAL= #787B86
C_GOLD   = #FFD700
C_WHITE  = #FFFFFF


// ══════════════════════════════════════════════════════════════════════════════
// ▶ CORE CALCULATIONS
// ══════════════════════════════════════════════════════════════════════════════
ema20  = ta.ema(close, ema_fast_len)
ema50  = ta.ema(close, ema_mid_len)
ema100 = ta.ema(close, ema_slow_len)
ema200 = ta.ema(close, ema_base_len)

psar = ta.sar(psar_start, psar_inc, psar_max)

vol_sma      = ta.sma(volume, vol_sma_len)
vol_ratio    = vol_sma > 0 ? volume / vol_sma : 1.0
vol_rising   = volume > vol_sma * vol_entry_mult
vol_strong   = volume > vol_sma * vol_strong_mult
// Volume declining = 2 consecutive bars of lower volume
vol_declining = volume < volume[1] and volume[1] < volume[2]

atr14 = ta.atr(14)


// ══════════════════════════════════════════════════════════════════════════════
// ▶ TREND STATE
// ══════════════════════════════════════════════════════════════════════════════
bull_trend = close > ema200 and ema20 > ema50 and ema50 > ema100
bear_trend = close < ema200 and ema20 < ema50 and ema50 < ema100

psar_below = psar < close  // bullish PSAR
psar_above = psar > close  // bearish PSAR

// Crossover triggers (close-based — cleaner than wick-based)
cross_up_ema20   = ta.crossover(close,  ema20)
cross_down_ema20 = ta.crossunder(close, ema20)

// Additional strong-trigger: simultaneous cross of both EMA20 & EMA50
cross_up_both   = cross_up_ema20   and close > ema50 and close[1] < ema50
cross_down_both = cross_down_ema20 and close < ema50 and close[1] > ema50


// ══════════════════════════════════════════════════════════════════════════════
// ▶ ENTRY SIGNALS
// ══════════════════════════════════════════════════════════════════════════════
long_signal  = bull_trend and cross_up_ema20   and vol_rising and psar_below
short_signal = bear_trend and cross_down_ema20 and vol_rising and psar_above

// Strong = full alignment + high-conviction volume + simultaneous 20/50 reclaim
strong_long  = long_signal  and vol_strong and cross_up_both
strong_short = short_signal and vol_strong and cross_down_both


// ══════════════════════════════════════════════════════════════════════════════
// ▶ POSITION TRACKING (for exit logic — bar counting since entry)
// ══════════════════════════════════════════════════════════════════════════════
var int  pos_dir       = 0       // +1 long, -1 short, 0 flat
var int  pos_bars      = 0       // bars elapsed since entry
var float pos_entry_px = na
var float pos_entry_sl = na

// Open a virtual position when an entry signal fires (only if currently flat)
if pos_dir == 0
    if long_signal
        pos_dir       := 1
        pos_bars      := 0
        pos_entry_px  := close
        pos_entry_sl  := psar
    else if short_signal
        pos_dir       := -1
        pos_bars      := 0
        pos_entry_px  := close
        pos_entry_sl  := psar

// Increment bar count on each new bar while in position
if pos_dir != 0
    pos_bars := pos_bars + 1


// ══════════════════════════════════════════════════════════════════════════════
// ▶ EXIT SIGNALS (priority: PSAR flip > trend break > time max > volume fade)
// ══════════════════════════════════════════════════════════════════════════════
var string exit_reason = ""

exit_long_psar    = pos_dir ==  1 and psar_above
exit_long_trend   = pos_dir ==  1 and close < ema20
exit_long_time    = pos_dir ==  1 and pos_bars >= exit_max_bars
exit_long_volfade = pos_dir ==  1 and pos_bars >= exit_min_bars and vol_declining

exit_short_psar    = pos_dir == -1 and psar_below
exit_short_trend   = pos_dir == -1 and close > ema20
exit_short_time    = pos_dir == -1 and pos_bars >= exit_max_bars
exit_short_volfade = pos_dir == -1 and pos_bars >= exit_min_bars and vol_declining

exit_long  = exit_long_psar  or exit_long_trend  or exit_long_time  or exit_long_volfade
exit_short = exit_short_psar or exit_short_trend or exit_short_time or exit_short_volfade

// Determine exit_reason string for payload
if exit_long_psar or exit_short_psar
    exit_reason := "psar_flip"
else if exit_long_trend or exit_short_trend
    exit_reason := "trend_break"
else if exit_long_time or exit_short_time
    exit_reason := "time_max"
else if exit_long_volfade or exit_short_volfade
    exit_reason := "volume_fade"

// Close virtual position on any exit
if exit_long or exit_short
    pos_dir       := 0
    pos_bars      := 0
    pos_entry_px  := na
    pos_entry_sl  := na


// ══════════════════════════════════════════════════════════════════════════════
// ▶ PLOTS — EMA Ribbon
// ══════════════════════════════════════════════════════════════════════════════
plot(ema20,  "EMA 20",  color=color.new(C_GOLD,    10), linewidth=2)
plot(ema50,  "EMA 50",  color=color.new(#FF9800,   20), linewidth=2)
plot(ema100, "EMA 100", color=color.new(#2196F3,   30), linewidth=1)
plot(ema200, "EMA 200", color=color.new(C_NEUTRAL, 20), linewidth=3)

// PSAR dots
plot(psar, "PSAR", style=plot.style_circles, color=psar_below ? color.new(C_BULL, 0) : color.new(C_BEAR, 0), linewidth=2)


// ══════════════════════════════════════════════════════════════════════════════
// ▶ ENTRY / EXIT SHAPES
// ══════════════════════════════════════════════════════════════════════════════
plotshape(strong_long,  "Strong Long",  shape.triangleup,   location.belowbar, color=C_BULL, size=size.normal, text="LONG 🥇", textcolor=C_BULL)
plotshape(strong_short, "Strong Short", shape.triangledown, location.abovebar, color=C_BEAR, size=size.normal, text="SHORT 🥇", textcolor=C_BEAR)
plotshape(long_signal  and not strong_long,  "Long",  shape.triangleup,   location.belowbar, color=color.new(C_BULL, 40), size=size.small)
plotshape(short_signal and not strong_short, "Short", shape.triangledown, location.abovebar, color=color.new(C_BEAR, 40), size=size.small)
plotshape(exit_long,    "Exit Long",    shape.xcross, location.abovebar, color=color.new(#FFA726, 0), size=size.tiny)
plotshape(exit_short,   "Exit Short",   shape.xcross, location.belowbar, color=color.new(#FFA726, 0), size=size.tiny)

// Background tint = trend quality
bgcolor(bull_trend ? color.new(C_BULL, 95) : bear_trend ? color.new(C_BEAR, 95) : na, title="Trend Regime BG")


// ══════════════════════════════════════════════════════════════════════════════
// ▶ DASHBOARD
// ══════════════════════════════════════════════════════════════════════════════
dash_t_pos = dash_pos == "Top Left" ? position.top_left : dash_pos == "Bottom Right" ? position.bottom_right : dash_pos == "Bottom Left" ? position.bottom_left : position.top_right

var table dash = table.new(dash_t_pos, 2, 10, bgcolor=color.new(#131722, 10), border_color=color.new(C_GOLD, 60), border_width=1, frame_color=color.new(C_GOLD, 40), frame_width=2)

if dash_show and barstate.islast
    trend_txt = bull_trend ? "🟢 BULL ALIGNED" : bear_trend ? "🔴 BEAR ALIGNED" : "⚪ NEUTRAL"
    trend_col = bull_trend ? C_BULL : bear_trend ? C_BEAR : C_NEUTRAL

    psar_txt = psar_below ? "BELOW (bullish)" : "ABOVE (bearish)"
    psar_col = psar_below ? C_BULL : C_BEAR

    vol_txt = vol_strong ? "STRONG" : vol_rising ? "RISING" : vol_declining ? "DECLINING" : "AVG"
    vol_col = vol_strong ? C_BULL : vol_rising ? C_GOLD : vol_declining ? C_BEAR : C_NEUTRAL

    sig_txt = strong_long ? "STRONG LONG" : strong_short ? "STRONG SHORT" : long_signal ? "LONG" : short_signal ? "SHORT" : exit_long ? "EXIT LONG" : exit_short ? "EXIT SHORT" : pos_dir == 1 ? "IN LONG (" + str.tostring(pos_bars) + "b)" : pos_dir == -1 ? "IN SHORT (" + str.tostring(pos_bars) + "b)" : "WAIT"
    sig_col = strong_long or long_signal ? C_BULL : strong_short or short_signal ? C_BEAR : exit_long or exit_short ? #FFA726 : C_NEUTRAL

    table.cell(dash, 0, 0, "SmartGold PSAR+EMA", text_color=C_GOLD, bgcolor=color.new(#131722, 0), text_size=size.normal)
    table.cell(dash, 1, 0, "H1 • XAU/USD",       text_color=C_WHITE, bgcolor=color.new(#131722, 0), text_size=size.small)

    table.cell(dash, 0, 1, "Trend Regime",  text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 1, trend_txt,       text_color=trend_col, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    table.cell(dash, 0, 2, "PSAR",          text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
    table.cell(dash, 1, 2, psar_txt,        text_color=psar_col,  bgcolor=color.new(#131722, 30), text_size=size.small)

    table.cell(dash, 0, 3, "EMA 20/50/100/200", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(ema20, "#.##") + " / " + str.tostring(ema50, "#.##") + " / " + str.tostring(ema100, "#.##") + " / " + str.tostring(ema200, "#.##"), text_color=C_GOLD, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    table.cell(dash, 0, 4, "Volume x SMA(" + str.tostring(vol_sma_len) + ")", text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(vol_ratio, "#.##") + "x — " + vol_txt, text_color=vol_col, bgcolor=color.new(#131722, 30), text_size=size.small)

    table.cell(dash, 0, 5, "ATR (14)",      text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 5, "$ " + str.tostring(atr14, "#.##"), text_color=C_GOLD, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    table.cell(dash, 0, 6, "Position",      text_color=C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)
    table.cell(dash, 1, 6, pos_dir == 0 ? "FLAT" : pos_dir == 1 ? "LONG (bar " + str.tostring(pos_bars) + "/" + str.tostring(exit_max_bars) + ")" : "SHORT (bar " + str.tostring(pos_bars) + "/" + str.tostring(exit_max_bars) + ")", text_color=pos_dir == 1 ? C_BULL : pos_dir == -1 ? C_BEAR : C_NEUTRAL, bgcolor=color.new(#131722, 30), text_size=size.small)

    table.cell(dash, 0, 7, "Last Exit Reason", text_color=C_NEUTRAL, bgcolor=color.new(#1E2230, 30), text_size=size.small)
    table.cell(dash, 1, 7, exit_reason == "" ? "-" : exit_reason, text_color=C_WHITE, bgcolor=color.new(#1E2230, 30), text_size=size.small)

    table.cell(dash, 0, 8, "Signal",        text_color=C_WHITE,   bgcolor=color.new(#0D47A1, 20), text_size=size.small)
    table.cell(dash, 1, 8, sig_txt,         text_color=sig_col,   bgcolor=color.new(#0D47A1, 20), text_size=size.normal)

    table.cell(dash, 0, 9, "Price",         text_color=C_NEUTRAL, bgcolor=color.new(#131722, 0), text_size=size.small)
    table.cell(dash, 1, 9, str.tostring(close, "#.##"), text_color=C_GOLD, bgcolor=color.new(#131722, 0), text_size=size.small)


// ══════════════════════════════════════════════════════════════════════════════
// ▶ LEGACY NAMED ALERTS (plain-text, for manual TradingView alerts)
// ══════════════════════════════════════════════════════════════════════════════
alertcondition(strong_long,  "🥇 Strong Long",   "SmartGold: STRONG LONG on XAU/USD — PSAR+EMA+Vol full alignment")
alertcondition(strong_short, "🥇 Strong Short",  "SmartGold: STRONG SHORT on XAU/USD — PSAR+EMA+Vol full alignment")
alertcondition(long_signal,  "📈 Long",          "SmartGold: Long entry on XAU/USD")
alertcondition(short_signal, "📉 Short",         "SmartGold: Short entry on XAU/USD")
alertcondition(exit_long,    "🚪 Exit Long",     "SmartGold: Exit LONG on XAU/USD")
alertcondition(exit_short,   "🚪 Exit Short",    "SmartGold: Exit SHORT on XAU/USD")


// ══════════════════════════════════════════════════════════════════════════════
// ▶ AI BRIDGE — WEBHOOK JSON ALERTS (alert() with dynamic runtime values)
// ──────────────────────────────────────────────────────────────────────────────
// TradingView setup:
//   1. Create alert → Condition = this indicator → "Any alert() function call"
//   2. Notifications → Webhook URL: https://your-vps/webhook/tradingview
//   3. Leave Message field empty (alert() supplies the full JSON body)
// ══════════════════════════════════════════════════════════════════════════════

// Build compact JSON payload. Piece-wise concat to keep Pine v6 line-wrap happy.
f_build_payload(string sig_name, string reason) =>
    s  = "{"
    s += "\"secret\":\""      + ai_webhook_secret + "\","
    s += "\"symbol\":\""      + syminfo.ticker    + "\","
    s += "\"timeframe\":\""   + timeframe.period  + "\","
    s += "\"signal\":\""      + sig_name          + "\","
    s += "\"price\":"         + str.tostring(close, "#.####") + ","
    s += "\"time\":\""        + str.format_time(time, "yyyy-MM-dd'T'HH:mm:ss'Z'", "UTC") + "\","
    s += "\"ema_fast\":"      + str.tostring(ema20,  "#.####") + ","
    s += "\"ema_mid\":"       + str.tostring(ema50,  "#.####") + ","
    s += "\"ema_slow\":"      + str.tostring(ema100, "#.####") + ","
    s += "\"ema_base\":"      + str.tostring(ema200, "#.####") + ","
    s += "\"psar\":"          + str.tostring(psar,   "#.####") + ","
    s += "\"psar_below\":"    + (psar_below ? "true" : "false") + ","
    s += "\"atr\":"           + str.tostring(atr14,  "#.####") + ","
    s += "\"volume\":"        + str.tostring(volume, "#.##")  + ","
    s += "\"volume_sma\":"    + str.tostring(vol_sma, "#.##") + ","
    s += "\"volume_ratio\":"  + str.tostring(vol_ratio, "#.####") + ","
    s += "\"bull_trend\":"    + (bull_trend ? "true" : "false") + ","
    s += "\"bear_trend\":"    + (bear_trend ? "true" : "false") + ","
    s += "\"bars_since_entry\":" + str.tostring(pos_bars) + ","
    s += "\"exit_reason\":\"" + reason + "\""
    s += "}"
    s

// ── Entries ───────────────────────────────────────────────────────────────
if ai_enable_webhook and strong_long and barstate.isconfirmed
    alert(f_build_payload("strong_long", ""), alert.freq_once_per_bar_close)

if ai_enable_webhook and strong_short and barstate.isconfirmed
    alert(f_build_payload("strong_short", ""), alert.freq_once_per_bar_close)

if ai_enable_webhook and ai_send_weak and long_signal and not strong_long and barstate.isconfirmed
    alert(f_build_payload("long", ""), alert.freq_once_per_bar_close)

if ai_enable_webhook and ai_send_weak and short_signal and not strong_short and barstate.isconfirmed
    alert(f_build_payload("short", ""), alert.freq_once_per_bar_close)

// ── Exits ─────────────────────────────────────────────────────────────────
if ai_enable_webhook and ai_send_exits and exit_long and barstate.isconfirmed
    alert(f_build_payload("exit_long", exit_reason), alert.freq_once_per_bar_close)

if ai_enable_webhook and ai_send_exits and exit_short and barstate.isconfirmed
    alert(f_build_payload("exit_short", exit_reason), alert.freq_once_per_bar_close)
